# Server configuration
PORT=3000

# Make.com webhook URL for automation triggers
MAKE_WEBHOOK_URL=https://hook.us1.make.com/your-webhook-id

# Google API credentials
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Drive folder ID for file storage
GOOGLE_DRIVE_FOLDER_ID=your-folder-id

# Google Sheets spreadsheet ID for data persistence
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id

# Skool API (if available)
SKOOL_API_KEY=your-skool-api-key

# Suno or music generation API
MUSIC_API_KEY=your-music-api-key
